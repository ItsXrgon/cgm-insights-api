# Application
APP_ENV=development # development, production, test
PORT=3000

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/cgm_insights

# Authentication
JWT_SECRET=your_jwt_secret_key_change_me_in_production

# Sentry (Optional)
SENTRY_DSN=

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000

# CGM background sync (optional, default: 3600 = 1 hour)
SYNC_INTERVAL_SECS=3600

# Rate Limiting
RATE_LIMIT_PERIOD_SECS=60
RATE_LIMIT_BURST=100

# Logging
RUST_LOG=info
