# Application
APP_ENV=development # development, production, test
PORT=3000

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/cgm_insights

# Authentication
JWT_SECRET=your_jwt_secret_key_change_me_in_production

# Sentry (Optional)
SENTRY_DSN=
# Override release (e.g. git SHA). Defaults to cargo package version.
# SENTRY_RELEASE=cgm-insights-api@abc1234
# Trace sampling 0.0–1.0. Default 1.0. 
# SENTRY_TRACES_SAMPLE_RATE=0.2

# CORS Configuration (production only; comma-separated for multiple origins)
ALLOWED_ORIGINS=http://localhost:3000

# CGM background sync (optional, default: 3600 * 10 = 10 hours)
SYNC_INTERVAL_SECS=36000

# Rate Limiting
RATE_LIMIT_PERIOD_SECS=60
RATE_LIMIT_BURST=100

# Logging
RUST_LOG=info
